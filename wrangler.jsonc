{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "shardloom",
  "compatibility_date": "2026-05-14",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "website",
    "html_handling": "none",
    "not_found_handling": "404-page"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
