---
import { benchmark, manifest, routeMetrics } from "../lib/data";

type TablePayload = {
  heading?: string;
  schema_version?: string;
  claim_boundary?: string;
  headers?: string[];
  rows?: unknown[][];
  [key: string]: unknown;
};

const metrics = routeMetrics();
const dashboard = (benchmark as any).comparative_dashboard ?? {};
const publishedRows = Array.isArray((benchmark as any).published_benchmark_rows) ? (benchmark as any).published_benchmark_rows : [];
const batchRows = Array.isArray((benchmark as any).batch_rows) ? (benchmark as any).batch_rows : [];
const publicFrontDoorRows = Array.isArray((benchmark as any).public_front_door_benchmark_rows) ? (benchmark as any).public_front_door_benchmark_rows : [];
const shardloomRows = publishedRows.filter((row: any) => String(row.engine ?? "").startsWith("shardloom"));
const sourceStateRows = batchRows.filter((row: any) => row.source_state_coverage_matrix);
const manifestAny = manifest as any;

function table(name: string): TablePayload {
  return (dashboard[name] ?? {}) as TablePayload;
}

function headers(payload: TablePayload, fallback: string[] = []): string[] {
  return Array.isArray(payload.headers) ? payload.headers : fallback;
}

function rows(payload: TablePayload): unknown[][] {
  return Array.isArray(payload.rows) ? payload.rows : [];
}

function tableObject(payload: TablePayload, row: unknown[]): Record<string, unknown> {
  const result: Record<string, unknown> = {};
  headers(payload).forEach((header, index) => {
    result[header] = row[index];
  });
  return result;
}

function objects(payload: TablePayload): Record<string, unknown>[] {
  return rows(payload).map((row) => tableObject(payload, row));
}

function textValue(value: unknown, fallback = "not reported"): string {
  if (value === null || value === undefined || value === "") return fallback;
  return String(value);
}

function statusClass(value: unknown): string {
  return `status-${textValue(value, "not-reported").replaceAll("_", "-")}`;
}

function parseMillis(value: unknown): number | null {
  const match = String(value ?? "").match(/([0-9]+(?:\.[0-9]+)?)\s*ms/);
  return match ? Number(match[1]) : null;
}

function percent(value: number | null, max: number): string {
  if (value === null || !Number.isFinite(value) || max <= 0) return "0";
  return String(Math.max(4, Math.min(100, (value / max) * 100)));
}

function rowValue(row: Record<string, unknown>, key: string, fallback = "not reported"): string {
  return textValue(row[key], fallback);
}

function routeCardId(route: string): string {
  const routeIds: Record<string, string> = {
    "ShardLoom Cold Certified Route": "cold_certified_route",
    "ShardLoom Prepare-Once First Query": "prepare_once_first_query",
    "ShardLoom Prepare-Once Batch": "prepare_once_batch",
    "ShardLoom Warm Prepared Query": "warm_prepared_query",
    "ShardLoom Native Vortex Query": "native_vortex_query",
    "External Baseline End-to-End": "external_baseline_end_to_end",
  };
  return routeIds[route] ?? route.toLowerCase().replace(/[^a-z0-9]+/g, "_").replace(/^_|_$/g, "");
}

function countBy(values: any[], key: string): Record<string, number> {
  const result: Record<string, number> = {};
  for (const row of values) {
    const value = textValue(row?.[key]);
    result[value] = (result[value] ?? 0) + 1;
  }
  return result;
}

function countEntries(values: Record<string, number>): [string, number][] {
  return Object.entries(values).sort((left, right) => {
    if (right[1] !== left[1]) return right[1] - left[1];
    return left[0].localeCompare(right[0]);
  });
}

function surfaceSort(row: Record<string, unknown>): number {
  const route = rowValue(row, "Route");
  const order = [
    "ShardLoom Warm Prepared Query",
    "ShardLoom Native Vortex Query",
    "ShardLoom Prepare-Once Batch",
    "ShardLoom Prepare-Once First Query",
    "ShardLoom Cold Certified Route",
  ];
  const index = order.indexOf(route);
  return index >= 0 ? index : order.length;
}

const routeLaneTable = table("route_lane_comparison");
const routeSurfaceTable = table("route_timing_surface_comparison");
const routeShareTable = table("route_share_amdahl");
const stageAttributionTable = table("stage_attribution");
const stageInclusionTable = table("stage_inclusion_contract");
const fastPathTable = table("fast_path_attribution");
const timingInstrumentTable = table("route_timing_instrument_readiness");
const runtimeTable = table("route_runtime_status");
const claimDistributionTable = table("claim_gate_distribution");
const profileLaneTable = table("profile_lane_availability");
const formatCoverageTable = table("format_coverage");
const closeoutTable = table("claim_grade_closeout");
const engineOverviewTable = table("engine_timing_overview");
const publicFrontDoorTable = table("public_front_door_routes");

const surfaceObjects = objects(routeSurfaceTable);
const routeShareObjects = objects(routeShareTable);
const fastPathObjects = objects(fastPathTable);
const stageInclusionObjects = objects(stageInclusionTable);

const hotRuntimeRows = surfaceObjects
  .filter((row) => rowValue(row, "Route").startsWith("ShardLoom") && rowValue(row, "Timing surface") === "hot_runtime")
  .sort((left, right) => surfaceSort(left) - surfaceSort(right));
const publicationRows = surfaceObjects
  .filter((row) => rowValue(row, "Route").startsWith("ShardLoom") && rowValue(row, "Timing surface") === "publication_proof")
  .sort((left, right) => surfaceSort(left) - surfaceSort(right));
const externalSurfaceRows = surfaceObjects.filter((row) => rowValue(row, "Timing surface") === "external_baseline");
const maxHot = Math.max(...hotRuntimeRows.map((row) => parseMillis(row["Surface route geomean"]) ?? 0), 1);
const maxPublication = Math.max(...publicationRows.map((row) => parseMillis(row["Surface route geomean"]) ?? 0), 1);

const optimizationTargets = routeShareObjects
  .filter((row) => rowValue(row, "Timing surface") === "hot_runtime")
  .map((row) => ({
    route: rowValue(row, "Route"),
    rows: rowValue(row, "Rows"),
    scale: rowValue(row, "Scale context"),
    routeGeomean: rowValue(row, "Hot route geomean"),
    stage: rowValue(row, "Dominant stage"),
    stageGeomean: rowValue(row, "Dominant stage geomean"),
    share: rowValue(row, "Dominant route share"),
    next: rowValue(row, "Next optimization target"),
    readiness: rowValue(row, "Optimization readiness"),
    notReady: rowValue(row, "Not-ready stages", "none"),
    score: parseMillis(row["Dominant stage geomean"]) ?? 0,
  }))
  .sort((left, right) => right.score - left.score);

const artifactRows = [
  ["Benchmark profile", textValue(manifestAny.benchmark_profile)],
  ["Promoted artifact status", textValue(manifestAny.artifact_status)],
  ["Generated UTC", textValue(manifestAny.generated_at_utc)],
  ["Benchmark git SHA", textValue(manifestAny.benchmark_git_sha)],
  ["ShardLoom git SHA", textValue(manifestAny.shardloom_git_sha)],
  ["Performance claim allowed", String(manifestAny.performance_claim_allowed ?? false)],
  ["Benchmark constitution gate", textValue(manifestAny.benchmark_constitution_claim_gate_status)],
  ["Route timing instrument status", textValue(manifestAny.route_timing_instrument_status)],
];
const artifactMirrorRows = [
  [
    "Canonical public artifact",
    "website-public/assets/benchmarks/latest/benchmark-results.json",
    "Astro publicDir source for benchmark evidence.",
  ],
  [
    "Generated website mirror",
    "website/assets/benchmarks/latest/benchmark-results.json",
    "Checked-in static output served by the website.",
  ],
  [
    "Website data snapshot",
    "website/assets/data/benchmark-evidence.json",
    "Static page data mirror for deployable asset paths.",
  ],
  [
    "Astro import snapshot",
    "website-src/src/data/benchmark-evidence.json",
    "Source import used by the benchmark dashboard build.",
  ],
];

const runtimeCounts = countBy(shardloomRows, "route_runtime_status");
const evidenceCounts = countBy(shardloomRows, "claim_gate_status");
const externalUnsupportedRows = publishedRows.filter((row: any) => !String(row.engine ?? "").startsWith("shardloom") && row.status === "unsupported").length;
const shardloomUnsupportedRows = shardloomRows.filter((row: any) => row.status === "unsupported" || row.route_runtime_status === "unsupported").length;
const benchmarkEtlSnippet = `from shardloom import context
import shardloom as sl

ctx = context(repo_root="/path/to/shardloom", profile_order=("release", "debug"))

fact = ctx.read_csv("data/fact.csv", schema={
    "id": "int64",
    "group_key": "int64",
    "dim_key": "int64",
    "value": "int64",
    "metric": "float64",
    "flag": "boolean",
    "category": "utf8",
    "event_date": "utf8",
    "nullable_metric_00": "float64",
    "raw_event_time": "utf8",
    "dirty_numeric": "utf8",
})
dim = ctx.read_csv("data/dim.csv", schema={
    "dim_key": "int64",
    "dim_label": "utf8",
    "weight": "float64",
})
events = ctx.read_json("data/events.jsonl", schema={
    "id": "int64",
    "nested_payload": "utf8",
})

# selective filter
fact.filter(sl.col("flag") == True).select("id", "group_key", "value").limit(1000).collect()

# filter + projection + limit
fact.filter(sl.col("value") >= 100).select("id", "group_key", "metric").limit(100).collect()

# group by aggregation
fact.filter(sl.col("metric") >= 0).group_by("group_key").agg(
    rows="count(*)",
    total_metric="sum(metric)",
).limit(100).collect()

# hash join
fact.join(dim, on="dim_key", how="inner").select(
    "f.id", "d.dim_label", "f.metric"
).limit(100).collect()

# global top-N; benchmark route owns the current top-N-per-group scenario
fact.select("id", "group_key", "metric").nlargest(10, "metric").collect()

# clean/cast/filter/write through the default local JSONL sink
fact.with_column("amount_float", sl.col("dirty_numeric").cast("float64")).filter(
    sl.col("amount_float") >= 0
).limit(1000).write_jsonl("target/clean-cast-filter-write.jsonl", allow_overwrite=True)

# malformed timestamp / dirty CSV, fail-closed unless cast path is admitted by current data
fact.with_column("event_day", sl.col("raw_event_time").cast("date32")).limit(1000).collect()

# null-heavy aggregate
fact.dropna(subset=["nullable_metric_00"]).group_by("group_key").agg(
    rows="count(*)",
    total_nullable_metric="sum(nullable_metric_00)",
).limit(100).collect()

# nested JSON field scan
events.filter(sl.col("nested_payload").contains("target")).select(
    "id", "nested_payload"
).limit(100).collect()`;
const localOutputSinkScopeRef = {
  source: "docs/architecture/v1-local-output-sink-scope.md",
  label: "v1 local output/sink scope",
  contextMethod: "local_output_sink_scope_report",
};
---

<section class="page-hero">
  <p class="eyebrow">Benchmarks</p>
  <h1>Benchmark Evidence, Not a Leaderboard</h1>
  <p class="lede">
    This page renders the promoted public artifact. Hot runtime, replay proof, publication proof, and external baseline surfaces stay separate so timing rows do not imply unsupported performance claims.
  </p>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Promoted artifact</p>
    <h2>The website results are current to the promoted artifact.</h2>
    <p class="narrow">
      The promoted bundle now includes the PERF-INNOV-5 hot-runtime metadata rows and full-local publication-proof rows. Performance claims remain disabled; the page is current evidence, not a leaderboard.
    </p>
  </div>
  <div class="artifact-panel">
    <div class="strip mini-strip embedded-strip">
      <div class="metric"><strong>{hotRuntimeRows.length}</strong><span>ShardLoom hot runtime surfaces</span></div>
      <div class="metric"><strong>{publicationRows.length}</strong><span>publication-proof surfaces</span></div>
      <div class="metric"><strong>{externalSurfaceRows.length}</strong><span>external baseline surfaces</span></div>
      <div class="metric"><strong>{String(manifestAny.performance_claim_allowed ?? false)}</strong><span>performance claim allowed</span></div>
    </div>
    <div class="table-wrap compact-table secondary-table">
      <table>
        <thead><tr><th>Artifact field</th><th>Value</th></tr></thead>
        <tbody>
          {artifactRows.map((row) => (
            <tr><td>{row[0]}</td><td>{row[1]}</td></tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="table-note">Artifact gate: <code>performance_claim_allowed=false</code>.</p>
  </div>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Benchmark data ownership</p>
    <h2>Static mirrors have one canonical artifact.</h2>
    <p class="narrow">
      The public-dir benchmark bundle owns the promoted data. Website source imports and generated static output must byte-match it, and mirror digest checks keep stale or partial benchmark evidence from replacing the canonical artifact.
    </p>
  </div>
  <div class="artifact-panel">
    <div class="table-wrap compact-table">
      <table>
        <thead><tr><th>Role</th><th>Path</th><th>Ownership</th></tr></thead>
        <tbody>
          {artifactMirrorRows.map((row) => (
            <tr><td>{row[0]}</td><td><code>{row[1]}</code></td><td>{row[2]}</td></tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="table-note">
      Readiness validation checks benchmark-results mirrors, manifest mirrors, row chunk SHA-256 values, and Cloudflare asset-size limits before the page can be treated as synchronized static output.
    </p>
  </div>
</section>

<section data-route-timing-surface-dashboard>
  <p class="eyebrow">Route timing dashboard</p>
  <h2>Route lanes are the comparison surface.</h2>
  <p class="narrow">
    Hot runtime rows drive the primary ShardLoom route grid. Publication-proof rows remain visible below and are intentionally slower when they include result-sink and human evidence rendering.
    Cold-certified route totals include raw-source ingest, Vortex write/reopen, and current input scale; warm prepared and native Vortex rows are the repeated-query timing lanes.
    External Baseline End-to-End rows are baseline context only and never ShardLoom fallback execution.
  </p>
  <div class="surface-grid">
    {hotRuntimeRows.map((row) => {
      const ms = parseMillis(row["Surface route geomean"]);
      const fastPath = fastPathObjects.find((candidate) => rowValue(candidate, "Route") === rowValue(row, "Route"));
      const inclusion = stageInclusionObjects.find((candidate) =>
        rowValue(candidate, "Route") === rowValue(row, "Route") && rowValue(candidate, "Timing surface") === "hot_runtime"
      );
      return (
        <article class="surface-card" data-route-card-id={routeCardId(rowValue(row, "Route"))}>
          <div class="route-card-topline">
            <span class="badge">hot_runtime</span>
            <span class="claim-chip">{rowValue(row, "Evidence tiers")}</span>
          </div>
          <h3>{rowValue(row, "Route")}</h3>
          <div class="surface-value">{rowValue(row, "Surface route geomean")}</div>
          <div class="surface-bar" aria-hidden="true"><span style={`--bar-width:${percent(ms, maxHot)}%`}></span></div>
          <dl class="route-card-facts">
            <div><dt>Route total</dt><dd>{rowValue(row, "Route total label")}</dd></div>
            <div><dt>Sink included</dt><dd>{rowValue(row, "Sink included")}</dd></div>
            <div><dt>Evidence render included</dt><dd>{rowValue(row, "Evidence render included")}</dd></div>
            <div><dt>Scale</dt><dd>{rowValue(row, "Scale context")}</dd></div>
            <div><dt>Runtime execution</dt><dd>{fastPath ? rowValue(fastPath, "Runtime execution") : "not reported"}</dd></div>
            <div><dt>Included hot runtime</dt><dd>{inclusion ? rowValue(inclusion, "Included hot runtime") : "not reported"}</dd></div>
          </dl>
          <p>{rowValue(row, "Formula")}</p>
        </article>
      );
    })}
  </div>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Publication proof</p>
    <h2>Proof-heavy rows stay visible, not mixed into hot runtime.</h2>
    <p class="narrow">
      Publication-proof route geomeans include result-sink and evidence-render work when the artifact says they are included. These rows prove more work; they do not replace missing hot-runtime rows.
    </p>
  </div>
  <div class="artifact-panel">
    <div class="surface-grid compact-surface-grid">
      {publicationRows.map((row) => {
        const ms = parseMillis(row["Surface route geomean"]);
        return (
          <article class="surface-card proof-card" data-route-card-id={`${routeCardId(rowValue(row, "Route"))}_publication_proof`}>
            <div class="route-card-topline">
              <span class="badge">publication_proof</span>
              <span class="claim-chip">{rowValue(row, "Evidence tiers")}</span>
            </div>
            <h3>{rowValue(row, "Route")}</h3>
            <div class="surface-value">{rowValue(row, "Surface route geomean")}</div>
            <div class="surface-bar proof-bar" aria-hidden="true"><span style={`--bar-width:${percent(ms, maxPublication)}%`}></span></div>
            <p>{rowValue(row, "Formula")}</p>
          </article>
        );
      })}
    </div>
  </div>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Optimization direction</p>
    <h2>Optimize the largest ShardLoom-owned hot route stages.</h2>
    <p class="narrow">
      Route-share attribution ranks measured stage cost inside the promoted artifact. It is planning evidence, not a public speed claim.
      If a target disappears or its stage timing reaches zero, the release report records <code>diagnostic_absent_or_retired</code> with <code>target_disappearance_policy=diagnostic_absent_or_retired_not_release_blocker</code>; artifact/fallback violations remain hard blockers.
    </p>
  </div>
  <div class="artifact-panel">
    <div class="strip mini-strip embedded-strip">
      <div class="metric"><strong>diagnostic</strong><span>retired optimization targets</span></div>
      <div class="metric"><strong>false</strong><span>release_blocker for retired targets</span></div>
      <div class="metric"><strong>false</strong><span>performance claim from target report</span></div>
    </div>
    <div class="route-card-grid compact-route-grid">
      {optimizationTargets.map((target) => (
        <article class="route-summary-card">
          <div class="route-card-topline">
            <span class="badge">{target.stage}</span>
            <span class:list={["status-chip", statusClass(target.readiness)]}>{target.readiness}</span>
          </div>
          <h3>{target.route}</h3>
          <div class="route-card-metrics">
            <div><span>Hot route geomean</span><strong>{target.routeGeomean}</strong></div>
            <div><span>Stage geomean</span><strong>{target.stageGeomean}</strong></div>
            <div><span>Route share</span><strong>{target.share}</strong></div>
            <div><span>Rows</span><strong>{target.rows}</strong></div>
          </div>
          <dl class="route-card-facts">
            <div><dt>Scale</dt><dd>{target.scale}</dd></div>
            <div><dt>Next target</dt><dd>{target.next}</dd></div>
            <div><dt>Not-ready stages</dt><dd>{target.notReady}</dd></div>
          </dl>
        </article>
      ))}
    </div>
    <p class="table-note">Route-share schema: {routeShareTable.schema_version ?? "not reported"}.</p>
  </div>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Stage attribution</p>
    <h2>Included, excluded, and diagnostic stages are explicit.</h2>
    <p class="narrow">
      Stage pieces explain route cost. They are not product lanes, and diagnostic-only fields must not be added into route totals.
    </p>
  </div>
  <div class="artifact-panel">
    <div class="table-wrap compact-table">
      <table>
        <thead>
          <tr>
            <th>Route</th><th>Surface</th><th>Rows</th><th>Included hot runtime</th><th>Included publication proof</th><th>Diagnostic only</th><th>Timing scope</th>
          </tr>
        </thead>
        <tbody>
          {stageInclusionObjects.map((row) => (
            <tr>
              <td>{rowValue(row, "Route")}</td>
              <td>{rowValue(row, "Timing surface")}</td>
              <td>{rowValue(row, "Rows")}</td>
              <td>{rowValue(row, "Included hot runtime")}</td>
              <td>{rowValue(row, "Included publication proof")}</td>
              <td>{rowValue(row, "Diagnostic only")}</td>
              <td>{rowValue(row, "Timing scope")}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <details class="drawer">
      <summary>Open full stage attribution table</summary>
      <div class="table-wrap compact-table">
        <table>
          <thead><tr>{headers(stageAttributionTable).map((header) => <th>{header}</th>)}</tr></thead>
          <tbody>{rows(stageAttributionTable).map((row) => <tr>{row.map((cell) => <td>{String(cell)}</td>)}</tr>)}</tbody>
        </table>
      </div>
    </details>
    <details class="drawer">
      <summary>Open route timing instrument readiness</summary>
      <div class="table-wrap compact-table">
        <table>
          <thead><tr>{headers(timingInstrumentTable).map((header) => <th>{header}</th>)}</tr></thead>
          <tbody>{rows(timingInstrumentTable).map((row) => <tr>{row.map((cell) => <td>{String(cell)}</td>)}</tr>)}</tbody>
        </table>
      </div>
    </details>
  </div>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Runtime and claims</p>
    <h2>Runtime support is separate from claim readiness.</h2>
    <p class="narrow">
      ShardLoom unsupported rows and External baseline unsupported rows are counted separately. External unsupported rows are baseline limitations, not ShardLoom runtime gaps.
    </p>
  </div>
  <div class="artifact-panel">
    <div class="strip mini-strip embedded-strip">
      <div class="metric"><strong>{metrics.scopedRuntimeSupported}</strong><span>scoped runtime rows</span></div>
      <div class="metric"><strong>{shardloomUnsupportedRows}</strong><span>ShardLoom unsupported rows</span></div>
      <div class="metric"><strong>{externalUnsupportedRows}</strong><span>External baseline unsupported rows</span></div>
      <div class="metric"><strong>{metrics.claimGrade}</strong><span>claim-grade evidence rows</span></div>
    </div>
    <div class="readiness-groups" aria-label="ShardLoom runtime and evidence status">
      <div>
        <span>Runtime</span>
        <div>{countEntries(runtimeCounts).map(([status, count]) => <span class="badge-count"><span class:list={["status-chip", statusClass(status)]}>{status}</span><span>{count}</span></span>)}</div>
      </div>
      <div>
        <span>Evidence</span>
        <div>{countEntries(evidenceCounts).map(([status, count]) => <span class="badge-count"><span class:list={["status-chip", statusClass(status)]}>{status}</span><span>{count}</span></span>)}</div>
      </div>
    </div>
  </div>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Public front doors</p>
    <h2>Route rows name the user-facing prepared paths.</h2>
    <p class="narrow">
      These rows bind public surfaces to route lanes, preparation boundaries, reuse posture, and no-fallback evidence. They are not timing rows. The v1 front-door boundary is owned by docs/architecture/v1-front-door-runtime-scope.md, the v1 Vortex runtime scope is owned by docs/architecture/v1-vortex-runtime-scope.md through local_vortex_primitive_route_report, and the v1 SourceState/prepared-state scope is owned by docs/architecture/v1-source-prepared-state-scope.md through source_prepared_state_scope_report.
    </p>
  </div>
  <div class="artifact-panel">
    <div class="route-card-grid compact-route-grid">
      {publicFrontDoorRows.map((row: any) => (
        <article class="route-summary-card public-front-door-card" data-public-front-door-id={row.front_door_id}>
          <div class="route-card-topline">
            <span class="badge">Front door</span>
            <span class="compare-chip compare-chip-muted">{row.benchmark_timing_status}</span>
          </div>
          <h3>{row.route_display_name}</h3>
          <p><code>{row.public_user_surface}</code></p>
          <dl class="route-card-facts">
            <div><dt>Front door</dt><dd>{row.front_door_id}</dd></div>
            <div><dt>Route lane</dt><dd>{row.route_lane_id}</dd></div>
            <div><dt>Start</dt><dd>{row.front_door_start_state}</dd></div>
            <div><dt>End</dt><dd>{row.front_door_end_state}</dd></div>
            <div><dt>Timing boundary</dt><dd>{row.benchmark_timing_boundary}</dd></div>
            <div><dt>Vortex normalization</dt><dd>{row.vortex_normalization_point}</dd></div>
            <div><dt>Source route</dt><dd>{row.source_route}</dd></div>
          </dl>
        </article>
      ))}
    </div>
    <div class="code-panel etl-snippet-panel">
      <div class="panel-label">Benchmark ETL scenarios from Python</div>
      <pre><code>{benchmarkEtlSnippet}</code></pre>
      <div class="code-evidence">
        <span><strong>route</strong>primary ShardLoom front door</span>
        <span><strong>timing</strong>promoted artifact only</span>
        <span><strong>output</strong>{localOutputSinkScopeRef.label}: {localOutputSinkScopeRef.contextMethod}</span>
        <span><strong>fallback_attempted</strong>false for ShardLoom rows</span>
      </div>
      <p class="table-note">Local output support is scoped by {localOutputSinkScopeRef.source}; feature-gated sinks remain local artifact evidence.</p>
    </div>
    <p class="table-note">Schema: {publicFrontDoorTable.schema_version ?? "not reported"}. Boundary: {publicFrontDoorTable.claim_boundary ?? "not reported"}.</p>
  </div>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Artifact lane availability</p>
    <h2>Expected lanes stay visible.</h2>
    <p class="narrow">Missing lanes are reported from the manifest instead of disappearing from the page.</p>
  </div>
  <div class="artifact-panel">
    <div class="table-wrap compact-table">
      <table>
        <thead><tr><th>Expected</th><th>Available</th><th>Missing</th><th>Format coverage rows</th></tr></thead>
