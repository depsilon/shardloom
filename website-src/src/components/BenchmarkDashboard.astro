---
import { benchmark, manifest, routeMetrics, runsTodayMatrix } from "../lib/data";

const metrics = routeMetrics();
const EVIDENCE_RENDER_PROOF_SCHEMA_VERSION = "shardloom.traditional_analytics.evidence_render_proof.v1";
const dashboard = (benchmark as any).comparative_dashboard ?? {};
const claimDistribution = dashboard.claim_gate_distribution ?? {};
const claimRows = Array.isArray(claimDistribution.rows) ? claimDistribution.rows : [];
const routeLaneTable = dashboard.route_lane_comparison ?? {};
const routeLaneRows = Array.isArray(routeLaneTable.rows) ? routeLaneTable.rows : [];
const routeLaneHeaders = Array.isArray(routeLaneTable.headers) ? routeLaneTable.headers : [];
const preparedAmortizationTable = dashboard.prepared_route_amortization ?? {};
const preparedAmortizationRows = Array.isArray(preparedAmortizationTable.rows) ? preparedAmortizationTable.rows : [];
const preparedAmortizationHeaders = Array.isArray(preparedAmortizationTable.headers) ? preparedAmortizationTable.headers : [];
const stageAttributionTable = dashboard.stage_attribution ?? {};
const stageAttributionRows = Array.isArray(stageAttributionTable.rows) ? stageAttributionTable.rows : [];
const stageAttributionHeaders = Array.isArray(stageAttributionTable.headers) ? stageAttributionTable.headers : [];
const fastPathTable = dashboard.fast_path_attribution ?? {};
const fastPathRows = Array.isArray(fastPathTable.rows) ? fastPathTable.rows : [];
const fastPathHeaders = Array.isArray(fastPathTable.headers) ? fastPathTable.headers : [];
const evidenceRenderProofTable = dashboard.evidence_render_proof ?? {};
const evidenceRenderProofRowsFromTable = Array.isArray(evidenceRenderProofTable.rows) ? evidenceRenderProofTable.rows : [];
const evidenceRenderProofHeaders = Array.isArray(evidenceRenderProofTable.headers) ? evidenceRenderProofTable.headers : [];
const operatorModeTable = dashboard.operator_mode_inventory ?? {};
const operatorModeRows = Array.isArray(operatorModeTable.rows) ? operatorModeTable.rows : [];
const operatorModeHeaders = Array.isArray(operatorModeTable.headers) ? operatorModeTable.headers : [];
const operatorCandidateTable = dashboard.operator_hot_path_candidates ?? {};
const operatorCandidateRows = Array.isArray(operatorCandidateTable.rows) ? operatorCandidateTable.rows : [];
const operatorCandidateHeaders = Array.isArray(operatorCandidateTable.headers) ? operatorCandidateTable.headers : [];
const routeRuntimeTable = dashboard.route_runtime_status ?? {};
const routeRuntimeRows = Array.isArray(routeRuntimeTable.rows) ? routeRuntimeTable.rows : [];
const engineOverview = dashboard.engine_timing_overview ?? {};
const engineHeaders = Array.isArray(engineOverview.headers) ? engineOverview.headers : ["Engine", "Available", "Success / total", "Geomean", "CSV/Parquet geomean", "Local fastest count"];
const engineRows = Array.isArray(engineOverview.rows) ? engineOverview.rows : [];
const profileLaneTable = dashboard.profile_lane_availability ?? {};
const profileLaneRows = Array.isArray(profileLaneTable.rows) ? profileLaneTable.rows : [];
const formatCoverage = dashboard.format_coverage ?? {};
const formatRows = Array.isArray(formatCoverage.rows) ? formatCoverage.rows : [];
const closeoutTable = dashboard.claim_grade_closeout ?? {};
const closeoutRows = Array.isArray(closeoutTable.rows) ? closeoutTable.rows : [];
const coldLaneTable = dashboard.cold_lane_attribution ?? {};
const coldLaneRows = Array.isArray(coldLaneTable.rows) ? coldLaneTable.rows : [];
const coldLaneHeaders = Array.isArray(coldLaneTable.headers) ? coldLaneTable.headers : ["Classification", "Timing split", "Primary bottleneck", "Source pressure", "Rows", "Optimization hint"];
const publishedRows = Array.isArray((benchmark as any).published_benchmark_rows) ? (benchmark as any).published_benchmark_rows : [];
const publicFrontDoorRows = Array.isArray((benchmark as any).public_front_door_benchmark_rows) ? (benchmark as any).public_front_door_benchmark_rows : [];
const publicFrontDoorTable = dashboard.public_front_door_routes ?? {};
const shardloomRows = publishedRows.filter((row: any) => String(row.engine ?? "").startsWith("shardloom"));
const exclusiveColdStageRows = shardloomRows
  .filter((row: any) => ["cold_certified_route", "prepare_once_first_query", "prepare_once_batch"].includes(String(row.route_lane_id ?? "")))
  .slice(0, 10)
  .map((row: any) => [
    textValue(row.route_display_name, textValue(row.engine)),
    textValue(row.storage_format),
    textValue(row.scenario_name),
    textValue(row.exclusive_stage_timing_status),
    formatMs(row.route_timing_exclusive_stage_sum_ms),
    formatMs(row.route_timing_exclusive_residual_ms),
    formatMs(row.inclusive_compatibility_to_vortex_import_ms),
    textValue(row.cold_bottleneck_primary_stage),
  ]);
const batchRows = Array.isArray((benchmark as any).batch_rows) ? (benchmark as any).batch_rows : [];
const sourceStateRows = batchRows.filter((row: any) => row.source_state_coverage_matrix);
const preparedLookupRows = batchRows.filter((row: any) =>
  row.prepare_batch_prepared_state_lookup_timing_schema_version
  || row.prepare_batch_prepared_state_lookup_status
);
const resultSinkCapillaryRows = publishedRows.filter((row: any) =>
  row.result_sink_capillary_schema_version
  || row.result_sink_capillary_status
);
const evidenceRenderProofRows = publishedRows.filter((row: any) =>
  row.evidence_render_proof_schema_version
  || row.evidence_render_proof_status
);
const manifestAny = manifest as any;
const supportCounts = (runsTodayMatrix as any).support_state_counts ?? {};
const supportRowCount = (runsTodayMatrix as any).row_count ?? 0;
const supportClaimBoundary = (runsTodayMatrix as any).claim_boundary ?? "not reported";
const supportDocsRef = (runsTodayMatrix as any).docs_ref ?? "docs/status/runs-today-support-matrix.json";

const ROUTE_CARD_ORDER = [
  "cold_certified_route",
  "prepare_once_first_query",
  "prepare_once_batch",
  "warm_prepared_query",
  "native_vortex_query",
] as const;

const ROUTE_CARD_COPY: Record<string, { eyebrow: string; scope: string; warning?: string; routeViewTokens: string[] }> = {
  cold_certified_route: {
    eyebrow: "Cold E2E",
    scope: "Raw compatibility input is admitted, ingested to Vortex, reopened, queried, and emitted with evidence in one route.",
    routeViewTokens: ["end-to-end", "diagnostic-stage"],
  },
  prepare_once_first_query: {
    eyebrow: "Prepare once",
    scope: "Raw compatibility input is prepared into VortexPreparedState, then the first prepared query and output route runs.",
    routeViewTokens: ["end-to-end", "diagnostic-stage"],
  },
  prepare_once_batch: {
    eyebrow: "Batch reuse",
    scope: "Raw compatibility input is prepared once, then multiple prepared scenarios reuse the same process state.",
    routeViewTokens: ["end-to-end", "diagnostic-stage"],
  },
  warm_prepared_query: {
    eyebrow: "Warm prepared",
    scope: "Query timing starts after VortexPreparedState already exists.",
    warning: "Not comparable to raw-source external end-to-end baselines.",
    routeViewTokens: ["prepared-state", "diagnostic-stage"],
  },
  native_vortex_query: {
    eyebrow: "Native Vortex",
    scope: "Input starts at the Vortex-native boundary, so compatibility preparation is not part of the route.",
    warning: "Not comparable to CSV/Parquet external end-to-end baselines.",
    routeViewTokens: ["native-vortex", "diagnostic-stage"],
  },
};

const BADGE_FIXTURE_RUNTIME_STATUSES = [
  "runtime_supported",
  "scoped_runtime_supported",
  "smoke_supported",
  "blocked",
  "unsupported",
];
const BADGE_FIXTURE_EVIDENCE_STATUSES = [
  "claim_grade",
  "external_baseline_only",
  "diagnostic_only",
];

function textValue(value: unknown, fallback = "not reported"): string {
  if (value === null || value === undefined || value === "") return fallback;
  return String(value);
}

function boolText(value: unknown): string {
  return value === true ? "yes" : "no";
}

function statusClass(value: unknown): string {
  return `status-${textValue(value, "not-reported").replaceAll("_", "-")}`;
}

function countBy(rows: any[], key: string): Record<string, number> {
  const counts: Record<string, number> = {};
  for (const row of rows) {
    const value = textValue(row?.[key]);
    counts[value] = (counts[value] ?? 0) + 1;
  }
  return counts;
}

function countEntries(counts: Record<string, number>): [string, number][] {
  return Object.entries(counts).sort((left, right) => {
    if (right[1] !== left[1]) return right[1] - left[1];
    return left[0].localeCompare(right[0]);
  });
}

function firstValue(rows: any[], key: string, fallback = "not reported"): string {
  for (const row of rows) {
    const value = row?.[key];
    if (value !== null && value !== undefined && value !== "") return String(value);
  }
  return fallback;
}

function routeLaneObject(row: unknown[]): Record<string, unknown> {
  const result: Record<string, unknown> = {};
  routeLaneHeaders.forEach((header: string, index: number) => {
    result[header] = row[index];
  });
  return result;
}

function stageObject(row: unknown[]): Record<string, unknown> {
  const result: Record<string, unknown> = {};
  stageAttributionHeaders.forEach((header: string, index: number) => {
    result[header] = row[index];
  });
  return result;
}

function parseMillis(value: unknown): number | null {
  const match = String(value ?? "").match(/([0-9]+(?:\.[0-9]+)?)\s*ms/);
  return match ? Number(match[1]) : null;
}

function formatMs(value: unknown): string {
  if (value === null || value === undefined || value === "") return "n/a";
  const numeric = Number(value);
  if (!Number.isFinite(numeric)) return String(value);
  return `${numeric.toFixed(2)} ms`;
}

function routeStageSummary(stage: Record<string, unknown> | undefined): string {
  if (!stage) return "Stage split not reported.";
  const total = textValue(stage["Total route"], "n/a");
  const source = textValue(stage["Source read"], "n/a");
  const parse = textValue(stage["Parse/decode"], "n/a");
  const array = textValue(stage["Source -> Vortex array"], "n/a");
  const write = textValue(stage["Vortex write"], "n/a");
  const prepCreate = textValue(stage["Prepared lookup/create"], "n/a");
  const query = textValue(stage["Vortex scan"], "n/a");
  const output = textValue(stage["Result sink"], "n/a");
  const evidence = textValue(stage["Evidence render"], "n/a");
  const prep = prepCreate !== "n/a"
    ? `prep/create ${prepCreate}`
    : `source ${source} / parse ${parse} / array ${array} / write ${write}`;
  return `total ${total}; ${prep}; scan ${query}; output ${output}; evidence ${evidence}`;
}

const routeLaneObjects: Record<string, unknown>[] = routeLaneRows.map((row: unknown[]) => routeLaneObject(row));
const routeLaneByDisplay: Map<string, Record<string, unknown>> = new Map(
  routeLaneObjects.map((row: Record<string, unknown>) => [textValue(row["Lane"]), row] as const),
);
const stageByDisplay: Map<string, Record<string, unknown>> = new Map(
  stageAttributionRows.map((row: unknown[]) => {
    const object = stageObject(row);
    return [textValue(object["Route"]), object] as const;
  }),
);

function shardloomRouteCard(laneId: string) {
  const rows = shardloomRows.filter((row: any) => row.route_lane_id === laneId);
  const displayName = firstValue(rows, "route_display_name", laneId);
  const laneSummary: Record<string, unknown> = routeLaneByDisplay.get(displayName) ?? {};
  const copy = ROUTE_CARD_COPY[laneId] ?? {
    eyebrow: "ShardLoom route",
    scope: "ShardLoom route evidence.",
    routeViewTokens: ["diagnostic-stage"],
  };
  const comparable = rows.some((row: any) => row.route_comparable_to_external_end_to_end === true);
  return {
    id: laneId,
    title: displayName,
    eyebrow: copy.eyebrow,
    scope: copy.scope,
    warning: copy.warning,
    rows,
    routeViewTokens: copy.routeViewTokens,
    runtimeStatuses: countBy(rows, "route_runtime_status"),
    evidenceStatuses: countBy(rows, "claim_gate_status"),
    successLabel: textValue(laneSummary["Success / total"], `${rows.filter((row: any) => row.status === "success").length}/${rows.length}`),
    geomeanLabel: textValue(laneSummary["Route geomean"], "not reported"),
    startState: textValue(laneSummary["Starts from"], firstValue(rows, "start_state")),
    includesPrepare: textValue(laneSummary["Includes prepare?"], boolText(rows.some((row: any) => row.includes_preparation === true))),
    timingScope: textValue(laneSummary["Prepare timing scope"], firstValue(rows, "route_timing_scope")),
    comparable,
    stageSummary: routeStageSummary(stageByDisplay.get(displayName)),
    performanceClaimAllowed: rows.some((row: any) => row.performance_claim_allowed === true),
    productionClaimAllowed: rows.some((row: any) => row.production_claim_allowed === true),
    sparkReplacementClaimAllowed: rows.some((row: any) => row.spark_replacement_claim_allowed === true),
  };
}

const externalRows = publishedRows.filter((row: any) => !String(row.engine ?? "").startsWith("shardloom"));
const externalLaneObjects: Record<string, unknown>[] = routeLaneObjects.filter((row: Record<string, unknown>) => !textValue(row["Lane"]).startsWith("ShardLoom"));
const externalGeomeans = externalLaneObjects
  .map((row: Record<string, unknown>) => parseMillis(row["Route geomean"]))
  .filter((value: number | null): value is number => value !== null)
  .sort((left: number, right: number) => left - right);
const externalRouteCard = {
  id: "external_baseline_end_to_end",
  title: "External Baseline End-to-End",
  eyebrow: "Baseline only",
  scope: "pandas, Polars, DuckDB, Dask, and DataFusion rows run from their normal raw-source path as comparison evidence, never ShardLoom fallback.",
  warning: "External rows are baseline context only. Unsupported baseline rows do not imply ShardLoom runtime gaps.",
  rows: externalRows,
  routeViewTokens: ["end-to-end"],
  runtimeStatuses: countBy(externalRows, "route_runtime_status"),
  evidenceStatuses: countBy(externalRows, "claim_gate_status"),
  successLabel: `${externalRows.filter((row: any) => row.status === "success").length}/${externalRows.length}`,
  geomeanLabel: externalGeomeans.length
    ? `${externalGeomeans[0].toFixed(2)}-${externalGeomeans[externalGeomeans.length - 1].toFixed(2)} ms by baseline lane`
    : "not reported",
  startState: "raw_compat_source",
  includesPrepare: "no",
  timingScope: "external_baseline_end_to_end",
  comparable: true,
  stageSummary: "External engines report their own raw-source end-to-end timing; ShardLoom stages do not apply.",
  performanceClaimAllowed: false,
  productionClaimAllowed: false,
  sparkReplacementClaimAllowed: false,
};
const routeCards = [
  ...ROUTE_CARD_ORDER.map((laneId) => shardloomRouteCard(laneId)).filter((card) => card.rows.length),
  ...(externalRows.length ? [externalRouteCard] : []),
];
---

<section class="page-hero">
  <p class="eyebrow">Benchmarks</p>
  <h1>Benchmark Evidence, Not a Leaderboard</h1>
  <p class="lede">
    The website renders committed static artifacts. Benchmark timing is interpreted beside the generated current-support matrix instead of restating support posture here.
  </p>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Current support source</p>
    <h2>Benchmarks reuse the status matrix.</h2>
    <p class="narrow">
      Runtime support counts come from <code>{supportDocsRef}</code>. The benchmark artifact supplies timing and coverage context; it is not the source of truth for support claims.
    </p>
  </div>
  <div class="artifact-panel">
    <div class="strip mini-strip embedded-strip">
      <div class="metric"><strong>{supportRowCount}</strong><span>support rows</span></div>
      <div class="metric"><strong>{supportCounts.executable ?? 0}</strong><span>executable</span></div>
      <div class="metric"><strong>{supportCounts.feature_gated ?? 0}</strong><span>feature-gated</span></div>
      <div class="metric"><strong>{supportCounts.blocked ?? 0}</strong><span>claim/platform blocked</span></div>
    </div>
    <p class="table-note">Support claim boundary: {supportClaimBoundary}.</p>
  </div>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Public front doors</p>
    <h2>Route rows name the user-facing prepared paths.</h2>
    <p class="narrow">
      The benchmark bundle publishes route-identity rows for the high-level Python front doors. These rows are not timing rows; they bind the public surface to the route lane, preparation boundary, reuse manifest, and no-fallback posture.
    </p>
  </div>
  <div class="artifact-panel">
    <div class="route-card-grid compact-route-grid">
      {publicFrontDoorRows.map((row: any) => (
        <article class="route-summary-card public-front-door-card" data-public-front-door-id={row.front_door_id}>
          <div class="route-card-topline">
            <span class="badge">Front door</span>
            <span class="compare-chip compare-chip-muted">{row.benchmark_timing_status}</span>
          </div>
          <h3>{row.route_display_name}</h3>
          <p><code>{row.public_user_surface}</code></p>
          <div class="route-card-metrics">
            <div><span>Front door</span><strong>{row.front_door_id}</strong></div>
            <div><span>Route lane</span><strong>{row.route_lane_id}</strong></div>
            <div><span>Start</span><strong>{row.front_door_start_state}</strong></div>
            <div><span>End</span><strong>{row.front_door_end_state}</strong></div>
          </div>
          <div class="readiness-groups" aria-label={`${row.front_door_id} readiness`}>
            <div>
              <span>Runtime</span>
              <div><span class:list={["status-chip", statusClass(row.route_runtime_status)]}>{row.route_runtime_status}</span></div>
            </div>
            <div>
              <span>Evidence</span>
              <div><span class:list={["status-chip", statusClass(row.claim_gate_status)]}>{row.claim_gate_status}</span></div>
            </div>
            <div>
              <span>Claims</span>
              <div>
                <span class="claim-chip">performance_claim_allowed={String(row.performance_claim_allowed)}</span>
                <span class="claim-chip">production_claim_allowed={String(row.production_claim_allowed)}</span>
                <span class="claim-chip">spark_replacement_claim_allowed={String(row.spark_replacement_claim_allowed)}</span>
              </div>
            </div>
          </div>
          <dl class="route-card-facts">
            <div><dt>Reuse scope</dt><dd>{row.prepared_state_reuse_scope}</dd></div>
            <div><dt>Normalization</dt><dd>{row.vortex_normalization_point}</dd></div>
            <div><dt>Timing boundary</dt><dd>{row.benchmark_timing_boundary}</dd></div>
          </dl>
        </article>
      ))}
    </div>
    <p class="table-note">Schema: {publicFrontDoorTable.schema_version ?? "not reported"}. Boundary: {publicFrontDoorTable.claim_boundary ?? "not reported"}.</p>
  </div>
</section>

<section>
  <p class="eyebrow">Route timing dashboard</p>
  <h2>Route lanes are the comparison surface.</h2>
  <p class="narrow">
    Stage pieces explain a ShardLoom route; they are not competing product lanes. Warm prepared and native Vortex rows stay labeled by start state.
  </p>
  <div class="route-card-shell" data-filter-scope data-route-card-dashboard>
    <div class="filter-bar route-filter-bar">
      <label>
        Route view
        <select data-filter="routeView">
          <option value="">All route cards</option>
          <option value="end-to-end">Comparable end-to-end</option>
          <option value="prepared-state">Prepared-state steady-state</option>
          <option value="native-vortex">Native Vortex only</option>
          <option value="diagnostic-stage">Diagnostics and stage rows</option>
        </select>
      </label>
      <label>
        Runtime
        <select data-filter="routeRuntime">
          <option value="">All runtime states</option>
          <option value="scoped_runtime_supported">Scoped runtime supported</option>
          <option value="external_baseline_only">External baseline only</option>
          <option value="unsupported">Unsupported visible</option>
        </select>
      </label>
      <label>
        Evidence
        <select data-filter="evidence">
          <option value="">All evidence states</option>
          <option value="claim_grade">Claim-grade evidence</option>
          <option value="external_baseline_only">External baseline evidence</option>
          <option value="unsupported">Unsupported evidence</option>
        </select>
      </label>
      <p class="filter-count" data-filter-count></p>
    </div>
    <div class="route-card-grid primary-route-grid">
      {routeCards.map((card) => (
        <article
          class:list={["route-summary-card", { "not-comparable": !card.comparable }]}
          data-filter-card
          data-route-card-id={card.id}
          data-route-view={card.routeViewTokens.join(" ")}
          data-route-runtime={countEntries(card.runtimeStatuses).map(([status]) => status).join(" ")}
          data-evidence={countEntries(card.evidenceStatuses).map(([status]) => status).join(" ")}
          data-route-card-e2e-comparable={String(card.comparable)}
        >
          <div class="route-card-topline">
            <span class="badge">{card.eyebrow}</span>
            <span class:list={["compare-chip", { "compare-chip-muted": !card.comparable }]}>
              {card.comparable ? "Comparable E2E" : "Not raw-source E2E"}
            </span>
          </div>
          <h3>{card.title}</h3>
          <p>{card.scope}</p>
          <div class="route-card-metrics">
            <div><span>Rows</span><strong>{card.successLabel}</strong></div>
            <div><span>Total route geomean</span><strong>{card.geomeanLabel}</strong></div>
            <div><span>Start</span><strong>{card.startState}</strong></div>
            <div><span>Includes prepare</span><strong>{card.includesPrepare}</strong></div>
          </div>
          <div class="readiness-groups" aria-label={`${card.title} readiness badges`}>
            <div>
              <span>Runtime</span>
              <div>
                {countEntries(card.runtimeStatuses).map(([status, count]) => (
                  <span class="badge-count">
                    <span class:list={["status-chip", statusClass(status)]}>{status}</span>
                    <span>{count}</span>
                  </span>
                ))}
              </div>
            </div>
            <div>
              <span>Evidence</span>
              <div>
                {countEntries(card.evidenceStatuses).map(([status, count]) => (
                  <span class="badge-count">
                    <span class:list={["status-chip", statusClass(status)]}>{status}</span>
                    <span>{count}</span>
                  </span>
                ))}
              </div>
            </div>
            <div>
              <span>Claims</span>
              <div>
                <span class="claim-chip">performance_claim_allowed={String(card.performanceClaimAllowed)}</span>
                <span class="claim-chip">production_claim_allowed={String(card.productionClaimAllowed)}</span>
                <span class="claim-chip">spark_replacement_claim_allowed={String(card.sparkReplacementClaimAllowed)}</span>
              </div>
            </div>
          </div>
          <dl class="route-card-facts">
            <div><dt>Timing scope</dt><dd>{card.timingScope}</dd></div>
            <div><dt>Stage split</dt><dd>{card.stageSummary}</dd></div>
          </dl>
          {card.warning && <p class="route-card-warning">{card.warning}</p>}
        </article>
      ))}
    </div>
    <div class="badge-fixture" data-route-badge-fixture>
      <div>
        <strong>Runtime badges</strong>
        <span>{BADGE_FIXTURE_RUNTIME_STATUSES.map((status) => (
          <span class:list={["status-chip", statusClass(status)]}>{status}</span>
        ))}</span>
      </div>
      <div>
        <strong>Evidence badges</strong>
        <span>{BADGE_FIXTURE_EVIDENCE_STATUSES.map((status) => (
          <span class:list={["status-chip", statusClass(status)]}>{status}</span>
        ))}</span>
      </div>
    </div>
    <details class="drawer">
      <summary>Open route lane ledger</summary>
      <div class="table-wrap compact-table">
        <table>
          <thead><tr>{routeLaneHeaders.map((header: string) => <th>{header}</th>)}</tr></thead>
          <tbody>
            {routeLaneRows.map((row: unknown[]) => (
              <tr>{row.map((cell) => <td>{String(cell)}</td>)}</tr>
            ))}
          </tbody>
        </table>
      </div>
    </details>
    <p class="table-note">Schema: {routeLaneTable.schema_version ?? "not reported"}. Boundary: {routeLaneTable.claim_boundary ?? "not reported"}.</p>
  </div>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Stage attribution</p>
    <h2>ShardLoom stage pieces explain route cost.</h2>
    <p class="narrow">Preparation, query, output, evidence, and diagnostic context are separated from route-level comparisons so a warm prepared slice cannot be read as a cold end-to-end route. The refreshed safe-writer artifact keeps exclusive stage timing visible for source read/parse, the inclusive import audit bundle, and workspace-safe Vortex write timing; the active child execution queue now records writer metadata coalescing, projection-aware text decode, source-admission packets, row-assembly strategy evidence, JSONL fast-path tail skipping, prepared-state lookup timing evidence, and result-sink capillary evidence before evidence rendering.</p>
  </div>
  <div class="artifact-panel">
    <div class="table-wrap compact-table">
      <table>
        <thead><tr>{stageAttributionHeaders.map((header: string) => <th>{header}</th>)}</tr></thead>
