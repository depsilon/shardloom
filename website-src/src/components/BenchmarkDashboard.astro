            <td>{Array.isArray(manifestAny.available_lanes) ? manifestAny.available_lanes.join(", ") : "not reported"}</td>
            <td>{Array.isArray(manifestAny.missing_lanes) && manifestAny.missing_lanes.length ? manifestAny.missing_lanes.join(", ") : "none"}</td>
            <td>{rows(formatCoverageTable).length}</td>
          </tr>
        </tbody>
      </table>
    </div>
    <details class="drawer">
