---
import { benchmark, manifest, routeMetrics, runsTodayMatrix } from "../lib/data";

const metrics = routeMetrics();
const dashboard = (benchmark as any).comparative_dashboard ?? {};
const claimDistribution = dashboard.claim_gate_distribution ?? {};
const claimRows = Array.isArray(claimDistribution.rows) ? claimDistribution.rows : [];
const routeLaneTable = dashboard.route_lane_comparison ?? {};
const routeLaneRows = Array.isArray(routeLaneTable.rows) ? routeLaneTable.rows : [];
const routeLaneHeaders = Array.isArray(routeLaneTable.headers) ? routeLaneTable.headers : [];
const stageAttributionTable = dashboard.stage_attribution ?? {};
const stageAttributionRows = Array.isArray(stageAttributionTable.rows) ? stageAttributionTable.rows : [];
const stageAttributionHeaders = Array.isArray(stageAttributionTable.headers) ? stageAttributionTable.headers : [];
const routeRuntimeTable = dashboard.route_runtime_status ?? {};
const routeRuntimeRows = Array.isArray(routeRuntimeTable.rows) ? routeRuntimeTable.rows : [];
const engineOverview = dashboard.engine_timing_overview ?? {};
const engineHeaders = Array.isArray(engineOverview.headers) ? engineOverview.headers : ["Engine", "Available", "Success / total", "Geomean", "CSV/Parquet geomean", "Local fastest count"];
const engineRows = Array.isArray(engineOverview.rows) ? engineOverview.rows : [];
const profileLaneTable = dashboard.profile_lane_availability ?? {};
const profileLaneRows = Array.isArray(profileLaneTable.rows) ? profileLaneTable.rows : [];
const formatCoverage = dashboard.format_coverage ?? {};
const formatRows = Array.isArray(formatCoverage.rows) ? formatCoverage.rows : [];
const closeoutTable = dashboard.claim_grade_closeout ?? {};
const closeoutRows = Array.isArray(closeoutTable.rows) ? closeoutTable.rows : [];
const coldLaneTable = dashboard.cold_lane_attribution ?? {};
const coldLaneRows = Array.isArray(coldLaneTable.rows) ? coldLaneTable.rows : [];
const publishedRows = Array.isArray((benchmark as any).published_benchmark_rows) ? (benchmark as any).published_benchmark_rows : [];
const shardloomRows = publishedRows.filter((row: any) => String(row.engine ?? "").startsWith("shardloom"));
const batchRows = Array.isArray((benchmark as any).batch_rows) ? (benchmark as any).batch_rows : [];
const sourceStateRows = batchRows.filter((row: any) => row.source_state_coverage_matrix);
const manifestAny = manifest as any;
const supportCounts = (runsTodayMatrix as any).support_state_counts ?? {};
const supportRowCount = (runsTodayMatrix as any).row_count ?? 0;
const supportClaimBoundary = (runsTodayMatrix as any).claim_boundary ?? "not reported";
const supportDocsRef = (runsTodayMatrix as any).docs_ref ?? "docs/status/runs-today-support-matrix.json";
---

<section class="page-hero">
  <p class="eyebrow">Benchmarks</p>
  <h1>Benchmark Evidence, Not a Leaderboard</h1>
  <p class="lede">
    The website renders committed static artifacts. Benchmark timing is interpreted beside the generated current-support matrix instead of restating support posture here.
  </p>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Current support source</p>
    <h2>Benchmarks reuse the status matrix.</h2>
    <p class="narrow">
      Runtime support counts come from <code>{supportDocsRef}</code>. The benchmark artifact supplies timing and coverage context; it is not the source of truth for support claims.
    </p>
  </div>
  <div class="artifact-panel">
    <div class="strip mini-strip embedded-strip">
      <div class="metric"><strong>{supportRowCount}</strong><span>support rows</span></div>
      <div class="metric"><strong>{supportCounts.executable ?? 0}</strong><span>executable</span></div>
      <div class="metric"><strong>{supportCounts.feature_gated ?? 0}</strong><span>feature-gated</span></div>
      <div class="metric"><strong>{supportCounts.blocked ?? 0}</strong><span>claim/platform blocked</span></div>
    </div>
    <p class="table-note">Support claim boundary: {supportClaimBoundary}.</p>
  </div>
</section>

<section>
  <p class="eyebrow">Route timing dashboard</p>
  <h2>Route lanes are the comparison surface.</h2>
  <p class="narrow">
    Stage pieces explain a ShardLoom route; they are not competing product lanes. Warm prepared and native Vortex rows stay labeled by start state.
  </p>
  <div class="artifact-panel">
    <div class="table-wrap compact-table">
      <table>
        <thead><tr>{routeLaneHeaders.map((header: string) => <th>{header}</th>)}</tr></thead>
        <tbody>
          {routeLaneRows.map((row: unknown[]) => (
            <tr>{row.map((cell) => <td>{String(cell)}</td>)}</tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="table-note">Schema: {routeLaneTable.schema_version ?? "not reported"}. Boundary: {routeLaneTable.claim_boundary ?? "not reported"}.</p>
  </div>
</section>

<section>
  <div class="strip mini-strip">
    <div class="metric"><strong>{manifestAny.benchmark_profile}</strong><span>benchmark profile</span></div>
    <div class="metric"><strong>{manifestAny.artifact_status}</strong><span>artifact completeness</span></div>
    <div class="metric"><strong>{metrics.availableLanes}/{metrics.expectedLanes}</strong><span>available lanes</span></div>
    <div class="metric"><strong>{metrics.scopedRuntimeSupported}</strong><span>scoped runtime rows</span></div>
    <div class="metric"><strong>{metrics.shardloomUnsupported}</strong><span>ShardLoom unsupported rows</span></div>
    <div class="metric"><strong>{metrics.externalUnsupported}</strong><span>external unsupported rows</span></div>
    <div class="metric"><strong>{metrics.claimGrade}</strong><span>evidence claim-grade rows</span></div>
    <div class="metric"><strong>{metrics.sourceStateRows}</strong><span>source-state rows</span></div>
    <div class="metric"><strong>{manifestAny.benchmark_constitution_claim_gate_status ?? "not reported"}</strong><span>constitution gate</span></div>
  </div>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Artifact lane availability</p>
    <h2>Expected lanes stay visible.</h2>
    <p class="narrow">Missing lanes are reported from the manifest instead of disappearing from the published page.</p>
  </div>
  <div class="artifact-panel">
    <div class="table-wrap compact-table">
      <table>
        <thead><tr><th>Profile</th><th>Lane</th><th>Role</th><th>Group</th><th>Status</th><th>Version / reason</th></tr></thead>
        <tbody>
          {profileLaneRows.map((row: unknown[]) => (
            <tr>{row.map((cell) => <td>{String(cell)}</td>)}</tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="table-note">
      Current artifact profile: <strong>{manifestAny.benchmark_profile}</strong>. Lane availability is generated by the benchmark promoter. The current
      <code>full_local</code> profile compares ShardLoom against local non-Spark baselines; <code>full_local_plus_spark</code> is the explicit-only Spark profile
      for <code>pyspark</code>, <code>spark-default</code>, and <code>spark-local-tuned</code>.
      Spark lanes are explicit-only historical baselines.
      Performance claim allowed: <strong>{String(manifestAny.performance_claim_allowed)}</strong>. Benchmark constitution claim gate:
      <strong>{String(manifestAny.benchmark_constitution_claim_gate_status ?? "not reported")}</strong>. Claim boundary: {manifestAny.claim_boundary}.
    </p>
  </div>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Benchmark constitution</p>
    <h2>Rows need route, correctness, environment, and no-fallback proof before claims.</h2>
    <p class="narrow">The manifest names the row validator and the field set required before any benchmark row can become claim-grade. Current static artifacts remain interpretation evidence, not public performance claims.</p>
  </div>
  <div class="artifact-panel">
    <dl class="definition-list">
      <div><dt>Schema</dt><dd>{manifestAny.benchmark_constitution_schema_version ?? "not reported"}</dd></div>
      <div><dt>Validator</dt><dd>{manifestAny.benchmark_constitution_validator ?? "not reported"}</dd></div>
      <div><dt>Claim gate</dt><dd>{manifestAny.benchmark_constitution_claim_gate_status ?? "not reported"}</dd></div>
      <div><dt>Performance claim allowed</dt><dd>{String(manifestAny.benchmark_constitution_performance_claim_allowed ?? false)}</dd></div>
    </dl>
    <p class="table-note">
      Required row fields: {Array.isArray(manifestAny.benchmark_constitution_required_field_order)
        ? manifestAny.benchmark_constitution_required_field_order.join(", ")
        : "not reported"}.
    </p>
  </div>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Stage attribution</p>
    <h2>ShardLoom stage pieces explain route cost.</h2>
    <p class="narrow">The attribution view keeps source admission, parse/decode, source-to-Vortex work, Vortex write/reopen, scan, operator compute, sink, and evidence rendering separate from route-level comparisons.</p>
  </div>
  <div class="artifact-panel">
    <div class="table-wrap compact-table">
      <table>
        <thead><tr>{stageAttributionHeaders.map((header: string) => <th>{header}</th>)}</tr></thead>
        <tbody>
          {stageAttributionRows.map((row: unknown[]) => (
            <tr>{row.map((cell) => <td>{String(cell)}</td>)}</tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="table-note">Schema: {stageAttributionTable.schema_version ?? "not reported"}. Boundary: {stageAttributionTable.claim_boundary ?? "not reported"}.</p>
  </div>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Cold-lane attribution</p>
    <h2>Cold ingest, warm query, sink, evidence, and harness timing stay separate.</h2>
    <p class="narrow">The promoter classifies each row before publication. Missing stage splits block claim-grade interpretation instead of letting cold preparation or harness overhead hide inside a single timing number.</p>
  </div>
  <div class="artifact-panel">
    <div class="table-wrap compact-table">
      <table>
        <thead><tr><th>Classification</th><th>Timing split</th><th>Rows</th></tr></thead>
        <tbody>
          {coldLaneRows.map((row: unknown[]) => (
            <tr>{row.map((cell) => <td>{String(cell)}</td>)}</tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="table-note">Schema: {coldLaneTable.schema_version ?? "not reported"}. Status: <strong>{coldLaneTable.status ?? "not reported"}</strong>.</p>
  </div>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Format coverage</p>
    <h2>CSV and Parquet are not the whole target roster.</h2>
    <p class="narrow">The published artifact now shows expected broad-format coverage instead of making absent JSONL, Arrow IPC, Avro, or ORC rows look irrelevant.</p>
  </div>
  <div class="artifact-panel">
    <div class="table-wrap compact-table">
      <table>
        <thead><tr><th>Format</th><th>Role</th><th>Status</th><th>Rows</th><th>Reason</th></tr></thead>
        <tbody>
          {formatRows.map((row: unknown[]) => (
            <tr>{row.map((cell) => <td>{String(cell)}</td>)}</tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Runtime status</p>
    <h2>Runtime support is separate from claim readiness.</h2>
    <p class="narrow">A row can be scoped-runtime-supported without authorizing performance, production, or Spark-replacement claims. External unsupported rows are baseline limitations, not ShardLoom runtime gaps.</p>
  </div>
  <div class="artifact-panel">
    <div class="table-wrap compact-table">
      <table>
        <thead><tr><th>Scope</th><th>Rows</th><th>Interpretation</th></tr></thead>
        <tbody>
          {routeRuntimeRows.map((row: unknown[]) => (
            <tr>{row.map((cell) => <td>{String(cell)}</td>)}</tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="table-note">Status vocabulary: {Array.isArray(routeRuntimeTable.status_vocabulary) ? routeRuntimeTable.status_vocabulary.join(", ") : "not reported"}.</p>
  </div>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Claim-gate distribution</p>
    <h2>Evidence quality is not the same as runtime support.</h2>
    <p class="narrow">Timing rows remain local context, not superiority proof. Compatibility cold timing is not pure query speed. Runtime support, evidence quality, and claim authorization are shown as separate layers.</p>
  </div>
  <div class="benchmark-preview">
    {claimRows.map((row: unknown[]) => (
      <div><span>{String(row[0])}</span><strong>{String(row[1])} rows - {String(row[2])}</strong></div>
    ))}
    <div><span>Prepared/native source-state evidence rows</span><strong>{sourceStateRows.length} batch rows</strong></div>
    <div><span>Published comparative roster</span><strong>{publishedRows.length} rows</strong></div>
  </div>
</section>

<section class="section-grid">
  <div>
    <p class="eyebrow">Claim-grade closeout</p>
    <h2>ShardLoom gaps and external baseline limits are counted separately.</h2>
    <p class="narrow">This page keeps runtime status, evidence quality, and claim authorization separate. External baseline unsupported rows do not imply a ShardLoom route gap.</p>
  </div>
  <div class="artifact-panel">
    <div class="table-wrap compact-table">
      <table>
        <thead><tr><th>Scope</th><th>Current rows</th><th>Target</th><th>Plan item</th></tr></thead>
        <tbody>
          {closeoutRows.map((row: unknown[]) => (
            <tr>{row.map((cell) => <td>{String(cell)}</td>)}</tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<section>
  <h2>Prepared/native source-state coverage</h2>
  <p class="narrow">Source-state coverage comes from prepared/native batch evidence, not the raw comparative timing rows. The matrix stays visible here so reuse evidence is not reduced to a single misleading count.</p>
  <details class="drawer">
    <summary>Open prepared/native source-state coverage</summary>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Requested mode</th><th>Scenarios</th><th>All classified</th><th>Reused</th><th>Not needed</th><th>Blocked</th><th>Unsupported</th><th>Prepare ms</th><th>Claim gate</th><th>Matrix</th></tr></thead>
        <tbody>
          {sourceStateRows.map((row: any) => (
            <tr>
              <td>{row.requested_execution_mode}</td>
              <td>{row.scenario_count}</td>
              <td data-field="source_state_coverage_all_requested_scenarios_classified">{String(row.source_state_coverage_all_requested_scenarios_classified)}</td>
              <td>{row.source_state_coverage_reused_scenario_count}</td>
              <td>{row.source_state_coverage_not_needed_scenario_count}</td>
              <td>{row.source_state_coverage_blocked_scenario_count}</td>
              <td>{row.source_state_coverage_unsupported_scenario_count}</td>
              <td>{row.source_state_prepare_millis}</td>
              <td>{row.claim_gate_status}</td>
              <td>{row.source_state_coverage_matrix}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </details>
</section>

<section>
  <h2>Raw timing tables</h2>
  <p class="narrow">Raw tables are collapsed by default. These rows retain source/read/parse/import/write/reopen/scan/operator/sink/evidence timing fields when present.</p>
  <details class="drawer">
    <summary>Engine timing overview</summary>
    <div class="table-wrap">
      <table>
        <thead><tr>{engineHeaders.map((header: string) => <th>{header}</th>)}</tr></thead>
        <tbody>
          {engineRows.map((row: unknown[]) => (
            <tr>{row.map((cell) => <td>{String(cell)}</td>)}</tr>
          ))}
        </tbody>
      </table>
    </div>
  </details>
  <details class="drawer">
    <summary>Published comparative roster ({publishedRows.length} rows)</summary>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Route</th><th>Internal lane</th><th>Scenario</th><th>Format</th><th>Status</th><th>Runtime</th><th>Mode</th><th>Total ms</th><th>Fallback</th><th>External engine</th><th>Claim gate</th></tr></thead>
        <tbody>
          {publishedRows.map((row: any) => (
            <tr>
              <td>{row.route_display_name ?? row.engine}</td><td>{row.engine}</td><td>{row.scenario_name}</td><td>{row.storage_format}</td><td>{row.status}</td><td>{row.route_runtime_status}</td><td>{row.selected_execution_mode}</td>
              <td>{row.total_runtime_millis}</td><td>{String(row.fallback_attempted)}</td><td>{String(row.external_engine_invoked)}</td><td>{row.claim_gate_status}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </details>
  <details class="drawer">
    <summary>ShardLoom detailed evidence rows ({shardloomRows.length} rows)</summary>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Route</th><th>Scenario</th><th>Mode</th><th>Format</th><th>Status</th><th>Runtime</th><th>Total route ms</th><th>Scan ms</th><th>Compute ms</th><th>Sink ms</th><th>Claim gate</th></tr></thead>
        <tbody>
          {shardloomRows.map((row: any) => (
            <tr>
              <td>{row.route_display_name ?? row.engine}</td><td>{row.scenario_name}</td><td>{row.selected_execution_mode}</td><td>{row.storage_format}</td><td>{row.status}</td><td>{row.route_runtime_status}</td>
              <td>{row.total_route_ms}</td><td>{row.vortex_scan_millis}</td><td>{row.operator_compute_millis}</td><td>{row.result_sink_write_millis}</td><td>{row.claim_gate_status}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </details>
</section>
