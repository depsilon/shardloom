---
import StatusChip from "./StatusChip.astro";
import ReferenceList from "./ReferenceList.astro";
import { formatList, useCases } from "../lib/data";

const statuses = [...new Set(useCases.map((item) => item.status))].sort();
const modes = [...new Set(useCases.map((item) => item.execution_mode))].sort();
---

<section class="page-hero">
  <p class="eyebrow">Use Case Atlas</p>
  <h1>Can ShardLoom do my thing?</h1>
  <p class="lede">
    Each use case names its status, execution route, evidence fields, references, and claim boundary so support is visible instead of implied.
  </p>
  <p class="blocked-note">Every executable use case must keep fallback_attempted=false, external_engine_invoked=false, and claim_gate_status visible when evidence is emitted.</p>
</section>

<section data-filter-scope>
  <div class="filter-bar">
    <label>Search <input type="search" data-filter="search" placeholder="CSV, Foundry, benchmark, output..." /></label>
    <label>Status
      <select data-filter="status">
        <option value="">All statuses</option>
        {statuses.map((status) => <option value={status}>{status}</option>)}
      </select>
    </label>
    <label>Execution route
      <select data-filter="mode">
        <option value="">All routes</option>
        {modes.map((mode) => <option value={mode}>{mode}</option>)}
      </select>
    </label>
    <p class="filter-count" data-filter-count></p>
  </div>
  <div class="use-case-grid">
    {useCases.map((item) => (
      <article
        class="use-case-card"
        data-filter-card
        data-status={item.status}
        data-mode={item.execution_mode}
        data-inputs={item.inputs.join(" ")}
        data-outputs={item.outputs.join(" ")}
      >
        <div class="card-top">
          <StatusChip value={item.status} />
          <span>{item.capability_family}</span>
        </div>
        <h3><a href={`/use-cases/${item.id}`}>{item.title}</a></h3>
        <dl class="mini-meta">
          <div><dt>Route</dt><dd>{item.execution_mode}</dd></div>
          <div><dt>Inputs</dt><dd>{formatList(item.inputs)}</dd></div>
          <div><dt>Outputs</dt><dd>{formatList(item.outputs)}</dd></div>
        </dl>
        <p class="blocked-note">{item.claim_boundary}</p>
        <ReferenceList references={item.references.slice(0, 3)} />
      </article>
    ))}
  </div>
</section>
