---
import StatusChip from "./StatusChip.astro";
import ReferenceList from "./ReferenceList.astro";
import { formatList, publicStatusRows, runsTodayMatrix, runsTodayRows } from "../lib/data";

const statuses = [...new Set(publicStatusRows.map((item) => item.status))].sort();
const platforms = [...new Set(publicStatusRows.map((item) => item.platform))].sort();
const supportStates = [...new Set(runsTodayRows.map((item) => item.support_state))].sort();
---

<section class="page-hero">
  <p class="eyebrow">Capability Status</p>
  <h1>Support status stays visible.</h1>
  <p class="lede">
    Runtime-supported, smoke-supported, report-only, blocked, unsupported, and not-planned paths remain in one filterable matrix.
  </p>
</section>

<section data-filter-scope>
  <div class="section-heading">
    <div>
      <p class="eyebrow">What Runs Today</p>
      <h2>Generated current-support matrix</h2>
    </div>
    <p class="lede compact-lede">
      {runsTodayMatrix.row_count} rows map CLI commands, Python APIs, input formats, output formats, execution modes, and claim boundaries.
    </p>
  </div>
  <div class="filter-bar">
    <label>Search <input type="search" data-filter="search" placeholder="CSV, Python, Vortex, package..." /></label>
    <label>Support
      <select data-filter="status">
        <option value="">All support states</option>
        {supportStates.map((status) => <option value={status}>{status}</option>)}
      </select>
    </label>
    <p class="filter-count" data-filter-count></p>
  </div>
  <div class="status-matrix">
    {runsTodayRows.map((row) => (
      <article
        class="status-row-card"
        data-filter-card
        data-status={row.support_state}
        data-platform={row.family}
        data-inputs={row.surface.join(" ")}
        data-outputs={row.evidence_refs.join(" ")}
      >
        <div class="card-top">
          <StatusChip value={row.support_state} />
          <span>{row.family}</span>
        </div>
        <h3>{row.id.replaceAll("_", " ")}</h3>
        <dl class="mini-meta">
          <div><dt>Surface</dt><dd>{formatList(row.surface)}</dd></div>
          <div><dt>Feature gate</dt><dd>{row.feature_gate}</dd></div>
          <div><dt>Evidence</dt><dd>{formatList(row.evidence_refs)}</dd></div>
          <div><dt>Blocker</dt><dd>{row.blocker_id}</dd></div>
          <div><dt>Claim boundary</dt><dd>{row.claim_boundary}</dd></div>
        </dl>
      </article>
    ))}
  </div>
</section>

<section data-filter-scope>
  <div class="section-heading">
    <div>
      <p class="eyebrow">Public Matrix</p>
      <h2>Capability-facing status rows</h2>
    </div>
  </div>
  <div class="filter-bar">
    <label>Search <input type="search" data-filter="search" placeholder="Local CSV, Foundry, S3, package..." /></label>
    <label>Status
      <select data-filter="status">
        <option value="">All statuses</option>
        {statuses.map((status) => <option value={status}>{status}</option>)}
      </select>
    </label>
    <label>Platform
      <select data-filter="platform">
        <option value="">All platforms</option>
        {platforms.map((platform) => <option value={platform}>{platform}</option>)}
      </select>
    </label>
    <p class="filter-count" data-filter-count></p>
  </div>
  <div class="status-matrix">
    {publicStatusRows.map((row) => (
      <article
        class="status-row-card"
        data-filter-card
        data-status={row.status}
        data-platform={row.platform}
        data-inputs={row.inputs.join(" ")}
        data-outputs={row.outputs.join(" ")}
      >
        <div class="card-top">
          <StatusChip value={row.status} />
          <span>{row.platform}</span>
        </div>
        <h3>{row.capability}</h3>
        <dl class="mini-meta">
          <div><dt>Route</dt><dd>{row.route}</dd></div>
          <div><dt>What works</dt><dd>{row.works}</dd></div>
          <div><dt>What is blocked</dt><dd>{row.blocked}</dd></div>
          <div><dt>Evidence required</dt><dd>{formatList(row.evidence)}</dd></div>
        </dl>
        <ReferenceList references={row.references.slice(0, 3)} />
      </article>
    ))}
  </div>
</section>
