---
import SiteLayout from "../layouts/SiteLayout.astro";
import { repoLink } from "../lib/data";

const docGroups = [
  {
    label: "Start",
    title: "Run a local proof",
    body: "Use the source checkout, local smokes, and evidence checks before inferring any support posture.",
    links: [
      ["Start local proof", "/start"],
      ["First 10 minutes source", repoLink("docs/getting-started/first-10-minutes.md")],
      ["Certified local workload", repoLink("docs/getting-started/certified-local-workload.md")],
    ],
  },
  {
    label: "Architecture",
    title: "Read the compute route",
    body: "Follow UniversalIngress, Vortex preparation, execution, output, and claim gates through the canonical architecture references.",
    links: [
      ["Compute flow", "/compute-engine-flow"],
      ["Architecture overview", "/architecture"],
      ["Completed execution ledger", repoLink("docs/architecture/phased-execution-completed-ledger.md")],
    ],
  },
  {
    label: "Evidence",
    title: "Interpret benchmark posture",
    body: "Benchmark artifacts are evidence surfaces, not public speed or replacement claims.",
    links: [
      ["Benchmark dashboard", "/benchmarks"],
      ["Local taxonomy benchmark", repoLink("docs/benchmarks/local-taxonomy-benchmark.md")],
      ["Benchmark suite catalog", repoLink("docs/architecture/benchmark-suite-catalog.md")],
    ],
  },
  {
    label: "Boundaries",
    title: "Keep claims fail-closed",
    body: "Release, Foundry, package, object-store, and production claims stay blocked until explicit evidence gates close.",
    links: [
      ["Status matrix", "/status"],
      ["No-fallback Field Guide", "/field-guide/no-fallback"],
      ["Known unsupported paths", repoLink("docs/release/known-unsupported-paths.md")],
    ],
  },
];
---

<SiteLayout title="Docs" description="ShardLoom documentation entry point for local proof, architecture, evidence, and claim boundaries." path="/docs" active="docs">
  <section class="page-hero">
    <p class="eyebrow">Docs</p>
    <h1>Source docs, routed for evidence.</h1>
    <p class="lede">
      Start from runnable local proof, then read architecture and benchmark evidence without treating the active implementation queue as public product documentation.
    </p>
    <div class="actions">
      <a class="button primary" href="/start">Start local proof</a>
      <a class="button" href="/field-guide">Open Field Guide</a>
      <a class="button ghost" href={repoLink("README.md")}>Open repository docs</a>
    </div>
  </section>

  <section class="section-grid">
    <div>
      <p class="eyebrow">Navigation</p>
      <h2>Use the repo docs as source of truth.</h2>
      <p class="narrow">
        The public site links to stable references and completed evidence. Active phase work stays in the repo queue until it lands and moves to the completed ledger.
      </p>
    </div>
    <div class="card-grid">
      {docGroups.map((group) => (
        <article class="card">
          <span class="badge">{group.label}</span>
          <h3>{group.title}</h3>
          <p>{group.body}</p>
          <ul class="reference-list source-link">
            {group.links.map(([label, href]) => (
              <li><a href={href}>{label}</a></li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section>
    <div class="strip mini-strip">
      <div class="metric"><strong>false</strong><span>fallback execution for ShardLoom rows</span></div>
      <div class="metric"><strong>local</strong><span>current proof boundary</span></div>
      <div class="metric"><strong>ledger</strong><span>completed phase provenance</span></div>
      <div class="metric"><strong>blocked</strong><span>production/package claims</span></div>
      <div class="metric"><strong>visible</strong><span>claim_gate_status evidence</span></div>
    </div>
  </section>
</SiteLayout>
