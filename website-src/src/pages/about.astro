---
import SiteLayout from "../layouts/SiteLayout.astro";
import { manifest, repoLink } from "../lib/data";

const manifestAny = manifest as any;
const manifestSha = String(manifestAny.benchmark_git_sha ?? manifestAny.shardloom_git_sha ?? "not reported");
---

<SiteLayout title="About" description="Claim-safe ShardLoom overview with current route, timing-surface, and evidence boundaries." path="/about" active="about">
  <section class="page-hero">
    <p class="eyebrow">About</p>
    <h1>ShardLoom is a Vortex-first local compute engine foundation.</h1>
    <p class="lede">
      It is pre-release, standalone from external query-engine fallback, and built to make source admission, Vortex preparation, execution, output, timing surface, and claim gates inspectable.
    </p>
    <div class="actions">
      <a class="button primary" href="/compute-engine-flow">View compute flow</a>
      <a class="button" href="/benchmarks">Inspect benchmarks</a>
      <a class="button ghost" href={repoLink("README.md")}>Open README</a>
    </div>
  </section>

  <section class="section-grid">
    <div>
      <p class="eyebrow">Identity</p>
      <h2>Vortex-native routes, no hidden delegation.</h2>
      <p class="narrow">
        ShardLoom treats Vortex input and output as first-class targets. Compatibility formats are explicit ingress or export boundaries, and unsupported work must return deterministic diagnostics.
      </p>
    </div>
    <div class="card-grid">
      <article class="card"><span class="badge">Native</span><h3>Vortex is the preferred persisted shape.</h3><p>Non-Vortex local sources enter through UniversalIngress, SourceState, and vortex_ingest before prepared_vortex execution.</p></article>
      <article class="card"><span class="badge">No fallback</span><h3>External engines do not execute ShardLoom work.</h3><p>Spark, DataFusion, DuckDB, Polars, Velox, and similar engines may appear only as baselines, oracles, or migration references.</p></article>
      <article class="card"><span class="badge">Evidence</span><h3>Outputs carry claim posture.</h3><p>Rows surface fallback_attempted, external_engine_invoked, claim_gate_status, evidence tier, and timing_surface fields where relevant.</p></article>
      <article class="card"><span class="badge">Pre-release</span><h3>Public claims stay gated.</h3><p>The site describes current local proof posture and the selected source/package release path. It does not claim production readiness, package availability before publication, or broad engine-replacement readiness.</p></article>
    </div>
  </section>

  <section class="section-grid">
    <div>
      <p class="eyebrow">Timing</p>
      <h2>Hot runtime is separated from proof publication.</h2>
      <p class="narrow">
        Benchmark route totals name their timing surface so proof-heavy rows cannot silently redefine hot route timing.
      </p>
    </div>
    <div class="surface-grid">
      <article class="surface-card">
        <span class="badge">hot_runtime</span>
        <h3>Runtime route surface</h3>
        <p>Default performance view. Result-sink replay and human evidence rendering are excluded unless the route formula explicitly includes them.</p>
      </article>
      <article class="surface-card">
        <span class="badge">full_replay_proof</span>
        <h3>Machine replay proof</h3>
        <p>Shows runtime plus replay or sink proof work when that row declares the cost as part of the proof surface.</p>
      </article>
      <article class="surface-card">
        <span class="badge">publication_proof</span>
        <h3>Publication-proof route</h3>
        <p>Includes result-sink and human evidence rendering when published evidence requires it. This is intentionally slower and labeled as proof work.</p>
      </article>
    </div>
  </section>

  <section>
    <div class="strip">
      <div class="metric"><strong>{String(manifestAny.performance_claim_allowed ?? "not reported")}</strong><span>performance_claim_allowed</span></div>
      <div class="metric"><strong>{String(manifestAny.route_timing_instrument_status ?? "not reported")}</strong><span>route timing instrument status</span></div>
      <div class="metric"><strong>{String(manifestAny.benchmark_constitution_claim_gate_status ?? "not reported")}</strong><span>benchmark claim gate</span></div>
      <div class="metric"><strong>{manifestSha.slice(0, 12)}</strong><span>promoted artifact SHA</span></div>
      <div class="metric"><strong>false</strong><span>runtime fallback delegation</span></div>
    </div>
  </section>
</SiteLayout>
