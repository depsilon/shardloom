{
  "name": "shardloom-website",
  "version": "0.1.6",
  "private": true,
  "type": "module",
  "description": "Astro/Starlight static website source for shardloom.io.",
  "scripts": {
    "sync-content": "node scripts/sync-content.mjs",
    "clean:static": "node scripts/prebuild-static.mjs",
    "settle:static": "node scripts/prebuild-static.mjs --settle-output",
    "prebuild:static": "node scripts/prebuild-static.mjs --reset-output",
    "dev": "npm run sync-content && astro dev --host 127.0.0.1",
    "build": "npm run prebuild:static && npm run sync-content && astro build && node scripts/postbuild-static.mjs",
    "preview": "astro preview --host 127.0.0.1",
    "check": "npm run clean:static && npm run sync-content && astro check && npm run settle:static"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/starlight": "^0.39.2",
    "astro": "^6.3.5",
    "typescript": "^5.9.3",
    "yaml": "^2.9.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "yaml-language-server": "1.23.0"
  }
}
