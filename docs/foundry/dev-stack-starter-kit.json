  "claim_boundary": "The Foundry dev-stack starter kit is a local Foundry-style generated-output and staged-transform proof only. It writes local result and evidence dataset-shaped artifacts through the dev-stack output API. It does not invoke real Foundry runtime, Foundry compute, Foundry Spark, real Foundry output APIs, direct S3/object-store I/O, external compute, or fallback execution, and it does not create a Foundry production, Marketplace, package, or platform claim.",
  "fallback_boundary": "Foundry, Spark, managed compute, object stores, and external engines cannot execute unsupported ShardLoom work as fallback.",
  "proof_commands": [
    {
      "command_id": "build_cli",
      "command": "cargo build -p shardloom-cli --bin shardloom",
      "purpose": "Build local CLI for the dev-stack proof."
    },
    {
      "command_id": "run_foundry_style_transform",
      "command": "python examples\\foundry-lightweight-transform\\run.py --repo-root .",
      "purpose": "Resolve the local package/client and CLI, run no-dataset smoke, execute generated-output and staged-input ShardLoom workflows, and write local Foundry-style result/evidence datasets."
    },
    {
      "command_id": "run_foundry_proof_of_use",
      "command": "python scripts\\foundry_proof_of_use.py --rows 64 --iterations 1",
      "purpose": "Run the combined local Foundry-style proof and local Vortex smoke evidence."
    }
  ],
  "local_outputs": [
    "target/foundry-lightweight-transform/certificate-output.json",
