    "scoped_conditional_rewrite_methods": {
      "mask": "typed scalar mask(predicate, scalar) over declared/projection columns through native Vortex expression-project",
      "replace": "typed full-cell scalar replace(old, new), column-mapped scalar replacement, and in-place UTF-8 with_column(\"col\", col(\"col\").replace(...)) through native Vortex expression-project"
    },
    "scoped_duplicate_mask_methods": {
      "duplicated": "subset-aware duplicated(..., keep='first'|'last'|False) boolean mask over declared/projection scalar columns through native/prepared Vortex duplicate-mask row-key state"
    },
    "scoped_plan_transform_methods": {
      "apply": "explicit sl.plan_transform(...) wrappers that return a ShardLoom LazyFrame during lazy plan construction; terminal execution remains on the resulting native/prepared route",
      "pipe": "explicit sl.plan_transform(...) wrappers that return a ShardLoom LazyFrame during lazy plan construction; terminal execution remains on the resulting native/prepared route"
    },
    "scoped_expression_runtime_methods": {
      "applymap": "explicit sl.column_transform(...) wrappers for declarative native/prepared Vortex expression-project rewrites; Python cell callables remain blocked",
      "eval": "in-place numeric scalar assignment such as eval(\"amount = amount + 5\") through the native/prepared Vortex expression-project primitive",
      "map": "explicit sl.column_transform(...) wrappers for declarative native/prepared Vortex expression-project rewrites; Python element callables remain blocked",
      "map_rows": "explicit sl.row_transform(...) wrappers for declarative native/prepared Vortex expression-project rewrites; Python row callables remain blocked",
      "transform": "mapping-style in-place numeric scalar assignment such as transform({\"amount\": sl.col(\"amount\") + 5}) through the native/prepared Vortex expression-project primitive"
    },
    "scoped_reshape_runtime_methods": {
      "melt": "explicit id_vars/value_vars flat scalar column-to-row expansion through the native/prepared Vortex melt primitive with same-typed value columns",
      "explode": "single declared scalar list/fixed-size-list column row expansion through the native/prepared Vortex explode primitive with explicit decode/materialization evidence",
      "pivot": "single index column, pivot column, and value column wide reshape through the native/prepared Vortex pivot primitive with first-unique duplicate-cell policy",
      "pivot_table": "single index column, pivot column, and value column aggregate reshape through the native/prepared Vortex pivot primitive with sum/count/mean aggregate kernels"
    },
    "scoped_window_runtime_methods": {
      "rolling": "rolling(window=<positive int>, min_periods<=window, center=false).sum/mean/count(column, alias=...) over one scalar source-order column through the native/prepared Vortex rolling-window primitive; sum/mean require numeric inputs and count admits scalar rows"
    },
